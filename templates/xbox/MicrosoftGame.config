<?xml version="1.0" encoding="utf-8"?>
<!--
  Microsoft GDK ゲーム構成ファイル。
  ID@Xbox で発行される TitleId / StoreId / MSAAppId 等を Partner Center の値に置き換えること。
  詳細: https://learn.microsoft.com/gaming/gdk/_content/gc/system/overviews/microsoft-game-config
-->
<Game configVersion="1">

  <Identity Name="Next2DGame"
            Publisher="CN=Next2D"
            Version="1.0.0.0" />

  <ExecutableList>
    <Executable Name="Next2DXboxHost.exe"
                Id="Game"
                TargetDeviceFamily="XboxOne;Scarlett" />
  </ExecutableList>

  <ShellVisuals DefaultDisplayName="Next2D Game"
                PublisherDisplayName="Next2D"
                StoreLogo="assets\StoreLogo.png"
                Square150x150Logo="assets\Square150x150Logo.png"
                Square44x44Logo="assets\Square44x44Logo.png"
                SplashScreenImage="assets\SplashScreen.png"
                Description="A game built with Next2D." />

  <!-- ID@Xbox 発行値に置き換える -->
  <MSAAppId>00000000000000000000000000000000</MSAAppId>
  <TitleId>00000000</TitleId>
  <StoreId>0000000000000000</StoreId>

  <VirtualMachineList>
    <VirtualMachine SandboxId="XDKS.1" TitleId="00000000" />
  </VirtualMachineList>

</Game>
